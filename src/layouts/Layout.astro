---
const { title } = Astro.props;
---

<!doctype html>
<html lang="fr">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap"
            rel="stylesheet"
        />
        <title>{title} | Astro-Stock</title>
        <style>
            :root[data-theme="dark"] {
                --bg: #0a0a0a;
                --bg2: #111111;
                --bg3: #1a1a1a;
                --border: #2a2a2a;
                --text: #ffffff;
                --text2: #888888;
                --accent: #ffffff;
                --btn-bg: #ffffff;
                --btn-text: #000000;
                --danger: #ff3333;
                --overlay: rgba(0, 0, 0, 0.85);
                --success: #00ff88;
            }

            :root[data-theme="light"] {
                --bg: #ffffff;
                --bg2: #fafafa;
                --bg3: #f0f0f0;
                --border: #e0e0e0;
                --text: #000000;
                --text2: #666666;
                --accent: #000000;
                --btn-bg: #000000;
                --btn-text: #ffffff;
                --danger: #cc0000;
                --overlay: rgba(0, 0, 0, 0.6);
                --success: #00cc66;
            }

            html {
                background-color: #0a0a0a;
            }

            html[data-theme="light"] {
                background-color: #ffffff;
            }
        </style>
        <script>
            (function () {
                const theme = localStorage.getItem("theme") || "dark";
                document.documentElement.setAttribute("data-theme", theme);
            })();
        </script>
    </head>
    <body>
        <nav class="navbar">
            <div class="nav-inner">
                <span class="nav-title">ASTRO-STOCK</span>
                <div class="nav-links">
                    <a href="/">Accueil</a>
                    <a href="/products">Inventaire</a>
                </div>
                <button class="theme-toggle" id="themeToggle">
                    <span class="theme-icon"></span>
                </button>
            </div>
        </nav>

        <main>
            <slot />
        </main>

        <footer class="footer">
            <p>Merci d'utiliser notre plateforme</p>
        </footer>

        <style is:global>
            * {
                margin: 0;
                padding: 0;
                box-sizing: border-box;
                border-radius: 0 !important;
                transition: none !important;
                animation: none !important;
            }

            body {
                font-family: "Poppins", sans-serif;
                background-color: var(--bg);
                color: var(--text);
                min-height: 100vh;
                display: flex;
                flex-direction: column;
            }

            a {
                text-decoration: none;
                color: inherit;
            }

            .navbar {
                border-bottom: 1px solid var(--border);
                padding: 0.5rem 1.5rem;
                background: var(--bg2);
                position: fixed;
                top: 0;
                left: 0;
                right: 0;
                z-index: 100;
            }

            .nav-inner {
                display: flex;
                align-items: center;
                gap: 2rem;
                max-width: 1400px;
                margin: 0 auto;
            }

            .nav-title {
                font-size: 0.85rem;
                font-weight: 600;
                letter-spacing: 0.15em;
                color: var(--text);
                white-space: nowrap;
            }

            .nav-links {
                display: flex;
                gap: 1.5rem;
                margin-left: auto;
            }

            .nav-links a {
                font-size: 0.75rem;
                letter-spacing: 0.05em;
                color: var(--text2);
                text-transform: uppercase;
                font-weight: 500;
            }

            .nav-links a:hover {
                color: var(--text);
            }

            .theme-toggle {
                background: transparent;
                border: 1px solid var(--border);
                width: 32px;
                height: 32px;
                cursor: pointer;
                display: flex;
                align-items: center;
                justify-content: center;
            }

            .theme-icon::before {
                content: "☀";
                font-size: 1rem;
                color: var(--text);
            }

            [data-theme="light"] .theme-icon::before {
                content: "☾";
            }

            .theme-toggle:hover {
                border-color: var(--text);
            }

            main {
                flex: 1;
                margin-top: 48px;
            }

            .footer {
                border-top: 1px solid var(--border);
                padding: 1.25rem;
                text-align: center;
                font-size: 0.75rem;
                color: var(--text2);
                background: var(--bg2);
                letter-spacing: 0.05em;
                font-weight: 400;
            }

            .btn {
                display: inline-block;
                padding: 0.7rem 1.5rem;
                border: 1px solid var(--text);
                background: var(--btn-bg);
                color: var(--btn-text);
                font-family: "Poppins", sans-serif;
                font-size: 0.85rem;
                font-weight: 500;
                letter-spacing: 0.05em;
                text-transform: uppercase;
                cursor: pointer;
            }

            .btn:hover {
                opacity: 0.85;
            }

            .btn-outline {
                background: transparent;
                color: var(--text);
                border: 1px solid var(--text);
            }

            .btn-outline:hover {
                background: var(--text);
                color: var(--bg);
            }

            .btn-danger {
                background: var(--danger);
                color: #ffffff;
                border: 1px solid var(--danger);
            }

            .form-group {
                margin-bottom: 1rem;
            }

            .form-group label {
                display: block;
                margin-bottom: 0.4rem;
                font-size: 0.75rem;
                letter-spacing: 0.05em;
                text-transform: uppercase;
                color: var(--text2);
                font-weight: 500;
            }

            .form-group input,
            .form-group textarea,
            .form-group select {
                width: 100%;
                padding: 0.7rem;
                background: var(--bg3);
                border: 1px solid var(--border);
                color: var(--text);
                font-family: "Poppins", sans-serif;
                font-size: 0.9rem;
                outline: none;
            }

            .form-group input:focus,
            .form-group textarea:focus,
            .form-group select:focus {
                border-color: var(--text);
            }

            .form-group select option {
                background: var(--bg2);
                color: var(--text);
            }

            .alert {
                padding: 0.8rem 1rem;
                margin-bottom: 1rem;
                font-size: 0.85rem;
                border: 1px solid;
                font-weight: 400;
            }

            .alert-success {
                border-color: var(--success);
                color: var(--success);
                background: rgba(0, 255, 136, 0.08);
            }

            .alert-error {
                border-color: var(--danger);
                color: var(--danger);
                background: rgba(255, 51, 51, 0.08);
            }

            .popup-overlay {
                position: fixed;
                inset: 0;
                background: var(--overlay);
                z-index: 999;
                display: flex;
                align-items: center;
                justify-content: center;
            }

            .popup-box {
                background: var(--bg);
                border: 1px solid var(--border);
                width: 90%;
                max-width: 600px;
                max-height: 90vh;
                overflow-y: auto;
                padding: 2rem;
            }

            .popup-header {
                display: flex;
                justify-content: space-between;
                align-items: center;
                margin-bottom: 1.5rem;
                padding-bottom: 1rem;
                border-bottom: 1px solid var(--border);
            }

            .popup-header h2 {
                font-size: 1rem;
                letter-spacing: 0.1em;
                text-transform: uppercase;
                font-weight: 600;
            }

            .popup-close {
                background: none;
                border: none;
                color: var(--text2);
                font-size: 1.5rem;
                cursor: pointer;
                padding: 0;
                width: 30px;
                height: 30px;
                display: flex;
                align-items: center;
                justify-content: center;
            }

            .popup-close:hover {
                color: var(--danger);
            }

            .popup-actions {
                display: flex;
                gap: 1rem;
                margin-top: 1.5rem;
                padding-top: 1rem;
                border-top: 1px solid var(--border);
            }
        </style>

        <script>
            const toggle = document.getElementById("themeToggle");
            const html = document.documentElement;

            toggle.addEventListener("click", () => {
                const current = html.getAttribute("data-theme");
                const next = current === "dark" ? "light" : "dark";
                html.setAttribute("data-theme", next);
                localStorage.setItem("theme", next);
            });
        </script>
    </body>
</html>
